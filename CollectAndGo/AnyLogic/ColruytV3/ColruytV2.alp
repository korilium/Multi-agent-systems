	<JavaClasses>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1774463291520</Id>
			<Name><![CDATA[NodeLoc]]></Name>
			<Text><![CDATA[import java.io.Serializable;
import java.util.*;  // for List and ArrayList
import com.anylogic.engine.Agent;

public class NodeLoc implements Serializable {
	
    public double x, y;               // coordinates
    public List<Edge> edges;          // connections to other nodes
    public Agent pointMarkup;         // AnyLogic Point Markup
    public double crowdedness = 1;    // spawn weight; higher = busier area

    // Constructor
    public NodeLoc(double x, double y) {
        this.x = x;
        this.y = y;
        this.edges = new ArrayList<>();
    }

    @Override
    public String toString() {
        return "NodeLoc(" + x + ", " + y + ")";
    }

    // Model snapshot
    private static final long serialVersionUID = 1L;

    // Edge class can be nested here or in a separate file
    public static class Edge {
    	public NodeLoc target;
        public double cost;
        public Edge(NodeLoc target, double cost){
            this.target = target;
            this.cost = cost;
        }
    }
}]]></Text>
		</JavaClass>
