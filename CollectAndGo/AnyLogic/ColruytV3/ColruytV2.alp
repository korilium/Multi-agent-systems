			<StartupCode><![CDATA[// ===== POPULATE globalNodes =====
globalNodes.add(new NodeLoc(node1.getX(), node1.getY()));
globalNodes.add(new NodeLoc(node2.getX(), node2.getY()));
globalNodes.add(new NodeLoc(node3.getX(), node3.getY()));
globalNodes.add(new NodeLoc(node4.getX(), node4.getY()));
globalNodes.add(new NodeLoc(node5.getX(), node5.getY()));
globalNodes.add(new NodeLoc(node6.getX(), node6.getY()));
globalNodes.add(new NodeLoc(node7.getX(), node7.getY()));
globalNodes.add(new NodeLoc(node8.getX(), node8.getY()));
globalNodes.add(new NodeLoc(node9.getX(), node9.getY()));
globalNodes.add(new NodeLoc(node10.getX(), node10.getY()));
globalNodes.add(new NodeLoc(node11.getX(), node11.getY()));
globalNodes.add(new NodeLoc(node12.getX(), node12.getY()));
globalNodes.add(new NodeLoc(node13.getX(), node13.getY()));
globalNodes.add(new NodeLoc(node14.getX(), node14.getY()));
globalNodes.add(new NodeLoc(node15.getX(), node15.getY()));
globalNodes.add(new NodeLoc(node16.getX(), node16.getY()));
globalNodes.add(new NodeLoc(node17.getX(), node17.getY()));
globalNodes.add(new NodeLoc(node18.getX(), node18.getY()));
globalNodes.add(new NodeLoc(node19.getX(), node19.getY()));
globalNodes.add(new NodeLoc(node20.getX(), node20.getY()));
globalNodes.add(new NodeLoc(node21.getX(), node21.getY()));
globalNodes.add(new NodeLoc(node22.getX(), node22.getY()));
globalNodes.add(new NodeLoc(node23.getX(), node23.getY()));
globalNodes.add(new NodeLoc(node24.getX(), node24.getY()));
globalNodes.add(new NodeLoc(node25.getX(), node25.getY()));
globalNodes.add(new NodeLoc(node26.getX(), node26.getY()));
globalNodes.add(new NodeLoc(node27.getX(), node27.getY()));
globalNodes.add(new NodeLoc(node28.getX(), node28.getY()));
globalNodes.add(new NodeLoc(node29.getX(), node29.getY()));
globalNodes.add(new NodeLoc(node30.getX(), node30.getY()));
globalNodes.add(new NodeLoc(node31.getX(), node31.getY()));
globalNodes.add(new NodeLoc(node32.getX(), node32.getY()));
globalNodes.add(new NodeLoc(node33.getX(), node33.getY()));
globalNodes.add(new NodeLoc(node34.getX(), node34.getY()));
globalNodes.add(new NodeLoc(node35.getX(), node35.getY()));
globalNodes.add(new NodeLoc(node36.getX(), node36.getY()));
globalNodes.add(new NodeLoc(node37.getX(), node37.getY()));
globalNodes.add(new NodeLoc(node38.getX(), node38.getY()));
globalNodes.add(new NodeLoc(node39.getX(), node39.getY()));
globalNodes.add(new NodeLoc(node40.getX(), node40.getY()));
globalNodes.add(new NodeLoc(node41.getX(), node41.getY()));
globalNodes.add(new NodeLoc(node42.getX(), node42.getY()));
globalNodes.add(new NodeLoc(node43.getX(), node43.getY()));
globalNodes.add(new NodeLoc(node44.getX(), node44.getY()));
globalNodes.add(new NodeLoc(node45.getX(), node45.getY()));
globalNodes.add(new NodeLoc(node46.getX(), node46.getY()));
globalNodes.add(new NodeLoc(node47.getX(), node47.getY()));
globalNodes.add(new NodeLoc(node48.getX(), node48.getY()));
globalNodes.add(new NodeLoc(node49.getX(), node49.getY()));
globalNodes.add(new NodeLoc(node50.getX(), node50.getY()));
 
// ===== SET CROWDEDNESS =====
// Ring road – center area (busy)
globalNodes.get(6).crowdedness = 8;   // node7
globalNodes.get(7).crowdedness = 7;   // node8
globalNodes.get(8).crowdedness = 7;   // node9
globalNodes.get(9).crowdedness = 5;   // node10
globalNodes.get(10).crowdedness = 5;  // node11
// Cross road (moderate)
globalNodes.get(0).crowdedness = 4;   // node1
globalNodes.get(1).crowdedness = 4;   // node2
globalNodes.get(2).crowdedness = 6;   // node3
globalNodes.get(3).crowdedness = 6;   // node4
globalNodes.get(4).crowdedness = 5;   // node5
globalNodes.get(5).crowdedness = 5;   // node6
globalNodes.get(12).crowdedness = 5;  // node13
// Outer ring (quiet)
globalNodes.get(29).crowdedness = 2;  // node30
globalNodes.get(38).crowdedness = 1;  // node39
globalNodes.get(44).crowdedness = 1;  // node45
 
// ===== BUILD ADJACENCY GRAPH =====
com.anylogic.engine.markup.Wall[] allWalls =
    {wall, wall1, wall2, wall3};
double wallThreshold = 3.0;
double maxEdgeDist = 100.0;
 
for (int i = 0; i < globalNodes.size(); i++) {
  for (int j = i+1; j < globalNodes.size(); j++){
    NodeLoc a = globalNodes.get(i);
    NodeLoc b = globalNodes.get(j);
    double dist = Math.sqrt(
        Math.pow(a.x-b.x,2)+Math.pow(a.y-b.y,2));
    if (dist > maxEdgeDist) continue;
 
    boolean blocked = false;
    int numSamples = Math.max(5,(int)(dist/5.0));
    for (int s=1; s<numSamples && !blocked; s++){
      double t = (double) s / numSamples;
      double sx = a.x + t*(b.x - a.x);
      double sy = a.y + t*(b.y - a.y);
      for (var w : allWalls) {
        Point pWall = new Point();
        w.getNearestPoint(sx, sy, pWall);
        double dw = Math.sqrt(
            Math.pow(sx-pWall.getX(),2)
          + Math.pow(sy-pWall.getY(),2));
        if (dw < wallThreshold) {
          blocked = true; break;
        }
      }
    }
    if (!blocked) {
      a.edges.add(new NodeLoc.Edge(b, dist));
      b.edges.add(new NodeLoc.Edge(a, dist));
    }
  }
}
traceln("Adjacency graph: "
      + globalNodes.size() + " nodes");
 
// ===== SPAWN INITIAL PEDESTRIANS =====
int initialCount =
    (int)(pedestrianArrivalRate() * 20);
for (int i = 0; i < initialCount; i++) {
    add_pedestrian();
}

// Robots start at node1 — fixed depot
robot.setXY(node1.getX(), node1.getY());
robot2.setXY(node1.getX(), node1.getY());
currentStart = globalNodes.get(0);
spawnDelayEvent.restart();
]]></StartupCode>
			<DestroyCode><![CDATA[// Stop spawning
eventSpawnPedestrian.reset();
source.set_arrivalType(source.MANUAL);
 
// Halt all active pedestrians
for (Pedestrian p : pedestrians) {
    p.stop();
}
 
// Halt the robot
if (robot != null) {
    robot.stop();
}]]></DestroyCode>
