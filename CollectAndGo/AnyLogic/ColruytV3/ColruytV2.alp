			<StatechartElements>
				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>1774786926425</Id>
					<Name><![CDATA[stWalking]]></Name>
					<X>170</X><Y>170</Y>
					<Label><X>25</X><Y>15</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="100" Height="30">
						<EntryAction><![CDATA[Main main = (Main) getOwner();
 
// Register in active pedestrians list
if (!main.pedestrians.contains(this)) {
    main.pedestrians.add(this);
}
 
// === 1. INITIALIZE (only on first entry) ===
if (parDestinationNode == null) {
    // Spawn at weighted-random node (crowdedness)
    double totalWeight = 0;
    for (NodeLoc n : main.globalNodes)
        totalWeight += n.crowdedness;
    double r = Math.random() * totalWeight;
    double cumulative = 0;
    NodeLoc currentNode = main.globalNodes.get(0);
    for (NodeLoc n : main.globalNodes) {
        cumulative += n.crowdedness;
        if (r < cumulative) {
            currentNode = n; break;
        }
    }
    setXY(currentNode.x, currentNode.y);
 
    // Random speed 0.8 – 1.6 m/s
    parSpeed = 0.8 + (Math.random() * 0.8);
 
    // Pick distant destination (>50m away)
    java.util.List<NodeLoc> candidates =
        new java.util.ArrayList<>();
    for (NodeLoc n : main.globalNodes) {
        double dist = Math.sqrt(
            Math.pow(n.x - getX(), 2)
          + Math.pow(n.y - getY(), 2));
        if (n != currentNode && dist > 50)
            candidates.add(n);
    }
    if (candidates.isEmpty())
        candidates.addAll(main.globalNodes);
    int idx = (int)(Math.random()
                   * candidates.size());
    parDestinationNode = candidates.get(idx);
}
 
// === 2. FIND CLOSEST GRAPH NODE ===
NodeLoc currentNode = null;
double closestDist = Double.MAX_VALUE;
for (NodeLoc n : main.globalNodes) {
    double d = Math.sqrt(
        Math.pow(n.x - getX(), 2)
      + Math.pow(n.y - getY(), 2));
    if (d < closestDist) {
        closestDist = d; currentNode = n;
    }
}
 
// === 3. GREEDY EDGE SELECTION ===
NodeLoc nextGraphNode = null;
if (currentNode != null
        && !currentNode.edges.isEmpty()) {
    NodeLoc bestNext = null;
    double bestProgress = -Double.MAX_VALUE;
    double dCurToDest = Math.sqrt(
        Math.pow(parDestinationNode.x - getX(), 2)
      + Math.pow(parDestinationNode.y - getY(), 2));
    for (NodeLoc.Edge e : currentNode.edges) {
        double dNext = Math.sqrt(
            Math.pow(e.target.x
                   - parDestinationNode.x, 2)
          + Math.pow(e.target.y
                   - parDestinationNode.y, 2));
        double progress = dCurToDest - dNext;
        if (progress > bestProgress) {
            bestProgress = progress;
            bestNext = e.target;
        }
    }
    nextGraphNode = (bestNext != null)
        ? bestNext
        : currentNode.edges.get(0).target;
} else {
    nextGraphNode = parDestinationNode;
}
 
// === 4. MOVE ===
moveTo(nextGraphNode.x, nextGraphNode.y, parSpeed);
]]></EntryAction>
						<FillColor>-16711936</FillColor>
					</Properties>
