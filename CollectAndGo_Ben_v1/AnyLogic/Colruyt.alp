				<Event>
					<Id>1773486861322</Id>
					<Name><![CDATA[eventPedestrianDeviationTracking]]></Name>
					<X>250</X><Y>490</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1773486861320</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1773561600000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[double totalDev = 0;
int count = 0;
for (PedestrianAgent ped : pedestrians) {
    totalDev += Math.abs(ped.getY()
        - ped.intendedY);
    count++;
}
if (count > 0) {
    pedDeviationData.add(time(),
        totalDev / count);
}]]></Action>
				</Event>
			
				<Event>
					<Id>1773500000005</Id>
					<Name><![CDATA[eventAdditionalKPIs]]></Name>
					<X>250</X><Y>530</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1773500000006</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1773561600000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[// === Additional KPI tracking ===
// 1. Average pedestrian speed
double totalSpeed = 0;
int pedCount = 0;
for (PedestrianAgent ped : pedestrians) {
    totalSpeed += ped.speed;
    pedCount++;
}
if (pedCount > 0) {
    avgPedSpeedData.add(time(), totalSpeed / pedCount);
}

// 2. Minimum robot-pedestrian distance
double minDist = 999;
for (DeliveryRobot robot : robots) {
    for (PedestrianAgent ped : pedestrians) {
        double d = robot.distanceTo(ped);
        if (d < minDist) {
            minDist = d;
        }
    }
}
if (minDist < 999) {
    minRobotPedDistData.add(time(), minDist);
}]]></Action>
				</Event>
			</Events>
			

