			<Events>
				<Event>
					<Id>1773484003872</Id>
					<Name><![CDATA[event]]></Name>
					<X>240</X><Y>50</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1773484003870</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1773561600000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[0.05]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[
// Pause execution entirely if currently loading/unloading
if (time() < loadingPauseUntil) return;

// ============================================================
// SECTION A: PERCEPTION — scan for nearest pedestrian
// ============================================================
// TWO separate scans:
//   1) FORWARD CONE (±60°) → used for stop/slow decisions.
//      Only pedestrians in the truck's path trigger stopping.
//      This avoids the Freezing Robot Problem (Trautman & Krause 2010)
//      where omnidirectional detection permanently freezes the truck.
//   2) OMNIDIRECTIONAL → stored for the movement clamp safety net
//      so the truck physically cannot drive into anyone from any angle.
double nearestFwdDist = scanRadius;   // forward cone — for stop/slow
double nearestFwdAngle = 0;
double nearestAnyDist = scanRadius;   // omnidirectional — for clamp
double nearestAnyAngle = 0;

for (PedestrianAgent ped : main.pedestrians) {
    double rawDist = distanceTo(ped);
    if (rawDist < scanRadius) {
        double pedAngle = Math.atan2(ped.getY() - getY(), ped.getX() - getX());

        // Omnidirectional (all directions) — for movement clamp
        if (rawDist < nearestAnyDist) {
            nearestAnyDist = rawDist;
            nearestAnyAngle = pedAngle;
        }

        // Forward cone (±60°) — for stop/slow decision
        double relAngle = pedAngle - heading;
        while (relAngle > Math.PI) relAngle -= 2 * Math.PI;
        while (relAngle < -Math.PI) relAngle += 2 * Math.PI;
        if (Math.abs(relAngle) < Math.PI / 3.0) {  // ±60°
            if (rawDist < nearestFwdDist) {
                nearestFwdDist = rawDist;
                nearestFwdAngle = pedAngle;
            }
        }
    }
}

// Store the distance used for statechart guards:
// Reactive mode uses omnidirectional, assertive uses forward cone
this.nearestPedDist = (behaviorMode == 0) ? nearestAnyDist : nearestFwdDist;

// Wall distances
double distTop = getY() - main.streetY;
double distBot = (main.streetY + main.streetWidth) - getY();


// ============================================================
// SECTION B: SPEED DECISION — based on FORWARD-CONE only
// ============================================================
// Uses nearestFwdDist (±60° cone) for stop/slow decisions.
// This prevents the Freezing Robot Problem: pedestrians behind
// or beside the truck do NOT trigger a stop.
// The omnidirectional movement clamp (Section D2) is the safety
// net for collisions from any angle.
// ============================================================
double currentSpeed = cruiseSpeed;
boolean shouldMove = true;

// Forward-cone distances:
// stopDist=20: pedestrian directly ahead → full stop
// slowDist=35: pedestrian approaching ahead → gradual slowdown
double stopDist = 20.0;
double slowDist = 35.0;

// Near the delivery target, reduce stop/slow thresholds so the robot
// can finish its journey even if pedestrians are nearby.
double distToTarget = distanceTo(targetX, targetY);
double effectiveStopDist = stopDist;
double effectiveSlowDist = slowDist;
if (distToTarget < 30) {
    // Shrink detection radii as we approach delivery point
    double factor = Math.max(0.2, distToTarget / 30.0);
    effectiveStopDist = stopDist * factor;
    effectiveSlowDist = slowDist * factor;
}

if (behaviorMode == 0) {
    // ---- REACTIVE MODE ----
    // Uses OMNIDIRECTIONAL distance (nearestAnyDist) — the robot treats
    // ALL nearby pedestrians as obstacles regardless of direction.
    // This is the overcautious planner that Trautman & Krause (2010)
    // show leads to the Freezing Robot Problem in dense crowds.
    if (nearestAnyDist < effectiveStopDist) {
        currentSpeed = 0;
        shouldMove = false;
    } else if (nearestAnyDist < effectiveSlowDist) {
        double ratio = (nearestAnyDist - effectiveStopDist) / (effectiveSlowDist - effectiveStopDist);
        currentSpeed = crawlSpeed + (cruiseSpeed - crawlSpeed) * ratio;
        if (nearestAnyDist < effectiveStopDist + 2) {
            currentSpeed = crawlSpeed * 0.3;
        }
    }
} else {
    // ---- ASSERTIVE MODE ----
    // Uses FORWARD-CONE distance (nearestFwdDist, ±60°) — the robot
    // only responds to pedestrians ahead, trusting side/rear pedestrians
    // to cooperate. This implements joint collision avoidance
    // (Trautman & Krause, 2010; Kretzschmar et al., 2016).
    if (nearestFwdDist < effectiveStopDist) {
        currentSpeed = crawlSpeed;
    } else if (nearestFwdDist < effectiveSlowDist) {
        double ratio = (nearestFwdDist - effectiveStopDist) / (effectiveSlowDist - effectiveStopDist);
        currentSpeed = crawlSpeed + (cruiseSpeed - crawlSpeed) * ratio;
    }
}

// Fire statechart events for visualisation sync
try {
    // Use the same distance the speed decision used
    double eventDist = (behaviorMode == 0) ? nearestAnyDist : nearestFwdDist;
    if (eventDist < slowDist) {
        statechart.fireEvent("pedestrianClose");
    } else {
        statechart.fireEvent("pathClear");
    }
} catch (Exception e) {
    // silently ignore — direct speed control above is authoritative
}


// ============================================================
// SECTION C2: DECENTRALIZED ROBOT-ROBOT NEGOTIATION (new)
// ============================================================
// Only runs when coordinationMode == 1 (decentralized).
// In centralized mode (0) or single-robot mode, this block
// is skipped entirely — the if-condition prevents execution.
//
// This modifies currentSpeed BEFORE Section D uses it.
// If this robot should yield, its speed drops to 30%.
// ============================================================
if (main.coordinationMode == 1) {
    for (DeliveryRobot other : main.robots) {
        if (other == this) continue;
        double dist = distanceTo(other);
        if (dist < scanRadius) {
            // Priority rule: robot closer to its goal goes first
            double myDist = distanceTo(targetX, targetY);
            double otherDist = other.distanceTo(
                other.targetX, other.targetY);
            if (myDist > otherDist) {
                // I'm further from my goal → I yield
                currentSpeed *= 0.3;
            }
        }
    }
}


// ============================================================
// SECTION D: MOVEMENT — turn and step using trig (L04)
// ============================================================
double candidateX = getX();
double candidateY = getY();
boolean hasCandidateMove = false;

if (shouldMove) {
    // Desired heading toward delivery target
    double desired = Math.atan2(
        targetY - getY(), targetX - getX());

    // Wall avoidance nudge
    if (distTop < 5) desired += 0.3;
    if (distBot < 5) desired -= 0.3;

    // Pedestrian avoidance — lateral dodge using FORWARD-CONE pedestrian
    // (nudge sideways relative to goal, not turn-away which aims backward)
    if (nearestFwdDist < slowDist) {
        double obstRelative = nearestFwdAngle - desired;
        double dodgeSign = (Math.sin(obstRelative) >= 0) ? -1 : 1;
        double proximity = 1.0 - (nearestFwdDist / slowDist);
        double maxDodge = (behaviorMode == 1) ? Math.PI / 8 : Math.PI / 5;
        desired = desired + dodgeSign * maxDodge * proximity;
    }

    // Turn toward desired heading (max turnRate per tick)
    double diff = desired - heading;
    while (diff > Math.PI) diff -= 2 * Math.PI;
    while (diff < -Math.PI) diff += 2 * Math.PI;
    double maxTurn = 0.08;
    heading += Math.max(-maxTurn, Math.min(maxTurn, diff));

    // Step forward using current speed
    // (may have been reduced by decentralized negotiation above)
    double dt = 0.05;
    double nx = getX() + currentSpeed * dt * Math.cos(heading);
    double ny = getY() + currentSpeed * dt * Math.sin(heading);

    // Clamp to street bounds
    ny = Math.max(main.streetY + 3,
        Math.min(main.streetY + main.streetWidth - 3, ny));

    // Store candidate position for clamp check below
    candidateX = nx;
    candidateY = ny;
    hasCandidateMove = true;
}

// ============================================================
// MOVEMENT CLAMP (runs ALWAYS, outside the shouldMove block)
// ============================================================
// Ultimate safety net: check if ANY pedestrian would be within 16
// units of the candidate position. If so, don't move. This runs
// outside the shouldMove block so the truck physically cannot drive
// into anyone even if the cone-based perception missed them.
// Exception: near the delivery target, reduce clamp to allow arrival.
if (hasCandidateMove) {
    double distToGoal = Math.sqrt(
        (candidateX - targetX) * (candidateX - targetX) +
        (candidateY - targetY) * (candidateY - targetY));
    // Near the goal, shrink the clamp so the robot can finish delivery
    double clampRadius = (distToGoal < 20) ? 8.0 : 16.0;

    boolean blocked = false;
    for (PedestrianAgent ped : main.pedestrians) {
        double pdx = candidateX - ped.getX();
        double pdy = candidateY - ped.getY();
        double pdist = Math.sqrt(pdx * pdx + pdy * pdy);
        if (pdist < clampRadius) {
            blocked = true;
            break;
        }
    }
    if (!blocked) {
        setXY(candidateX, candidateY);
    }
    // If blocked: heading was updated above, so next tick the truck
    // may steer around. Position stays unchanged = truck visibly stops.
}


// ============================================================
// ============================================================
// SECTION E: CONTINUOUS DELIVERY WORKFLOW
// ============================================================
// The robot pauses to load/unload, then reverses direction.

// Arrival check logic (left-to-right uses targetX - 10, right-to-left uses targetX + 10)
boolean hasArrived = (!isReturning && getX() >= targetX - 10) || (isReturning && getX() <= targetX + 10);

if (hasArrived) {
    if (!isReturning) {
        // DELIVERED TO CUSTOMER (Right side)
        double deliveryTime = time() - startTime;
        main.deliveryTimeData.add(deliveryTime);
        main.freezeCountData.add(freezeCount);
        main.completedOrders++; // increment our continuous KPI
        
        traceln(green, "Delivery Completed! Time: " + String.format(java.util.Locale.US, "%.1f", deliveryTime) + "s, freezes: " + freezeCount + ". Total Deliveries: " + main.completedOrders);
        
        // Write batch data natively to experiment_results.csv using Java I/O
        try (java.io.PrintWriter out = new java.io.PrintWriter(new java.io.FileWriter("experiment_results.csv", true))) {
            out.println(String.format(
                java.util.Locale.US, "%.1f,%d,%d,%d,%d,%.1f,%.2f,%.2f",
                time(), behaviorMode, main.numPedestrians, main.completedOrders,
                (int) main.freezeCountData.getYMax(), deliveryTime, 
                main.avgPedSpeedData.getYMax(), main.minRobotPedDistData.getYMin()
            ));
        } catch (java.io.IOException e) {
            traceln(red, "Error writing to CSV: " + e.getMessage());
        }
        
        // Setup return trip (Drive right-to-left)
        isReturning = true;
        targetX = 5; // Left edge
        heading = Math.PI; // Face left
        freezeCount = 0;
        loadingPauseUntil = time() + 15.0; // Unload groceries for 15 seconds
        traceln("Unloading... paused for 15s");
        
    } else {
        // PICKED UP NEW ORDER (Left side)
        isReturning = false;
        targetX = main.streetLength - 5; // Right edge
        heading = 0; // Face right
        startTime = time() + 30.0; // Start new timer AFTER loading
        freezeCount = 0;
        loadingPauseUntil = time() + 30.0; // Load new groceries for 30 seconds
        traceln("Loading new order... paused for 30s");
    }
}]]></Action>
				</Event>
			</Events>
			<Functions>
