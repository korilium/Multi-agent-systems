		<!--   =========   Active Object Class   ========  -->
		<ActiveObjectClass>
			<Id>1773430427526</Id>
			<Name><![CDATA[Main]]></Name>
			<StartupCode><![CDATA[// FIXED RANDOM SEED FOR REPRODUCIBILITY
getEngine().randomSeed(12345);
traceln(green, "========================================");
traceln(green, "SIMULATION RUNNING WITH FIXED SEED: 12345");
traceln(green, "Results are REPRODUCIBLE and verifiable.");
traceln(green, "========================================");

// Street layout: Y goes from streetY (top wall) to streetY+streetWidth (bottom wall)
// Right-hand traffic (Belgian convention):
//   Going right (fromLeft): bottom half (higher Y)
//   Going left (!fromLeft): top half (lower Y)
double streetCenter = streetY + streetWidth / 2;

// Spawn pedestrians from the EDGES of the street (left, right, top, bottom).
// Each pedestrian enters from one edge and walks toward the opposite edge.
for (int i = 0; i < numPedestrians; i++) {
    PedestrianAgent ped = add_pedestrians();

    // Heterogeneous characteristics (Macal: individuality)
    // Log-normal speed (Weidmann 1993)
    ped.speed = Math.max(0.5, normal(1.34, 0.26)); // Weidmann (1993) empirical speed
    ped.comfortDistance = uniform(4.0, 8.0);
    ped.turnRate = uniform(0.06, 0.14);

    double startX, startY, gx, gy;
    // Pick a random edge: 70% along street (0=left, 1=right), 30% crossing
    int edge;
    if (uniform(0, 1) < 0.7) {
        edge = (uniform(0, 1) < 0.5) ? 0 : 1;
    } else {
        edge = (uniform(0, 1) < 0.5) ? 2 : 3;
    }
    if (edge == 0) {
        // Enter from LEFT edge, walk right
        startX = 5;
        startY = streetCenter + uniform(5, streetWidth / 2 - 5);
        gx = streetLength - 5;
        gy = streetCenter + uniform(5, streetWidth / 2 - 5);
    } else if (edge == 1) {
        // Enter from RIGHT edge, walk left
        startX = streetLength - 5;
        startY = streetY + uniform(5, streetWidth / 2 - 5);
        gx = 5;
        gy = streetY + uniform(5, streetWidth / 2 - 5);
    } else if (edge == 2) {
        // Enter from TOP edge, walk down (crossing the street)
        startX = uniform(20, streetLength - 20);
        startY = streetY + 3;
        gx = uniform(20, streetLength - 20);
        gy = streetY + streetWidth - 3;
    } else {
        // Enter from BOTTOM edge, walk up (crossing the street)
        startX = uniform(20, streetLength - 20);
        startY = streetY + streetWidth - 3;
        gx = uniform(20, streetLength - 20);
        gy = streetY + 3;
    }

    ped.setXY(startX, startY);
    ped.goalX = gx;
    ped.goalY = gy;
    ped.intendedY = startY;
    ped.heading = Math.atan2(gy - startY, gx - startX);
}

// Group pedestrians into social clusters of 2-3
for (int g = 0; g < numPedestrians / 4; g++) {
    int groupSize = 2 + (int)(uniform(0, 2)); // 2 or 3
    if (g * 3 + groupSize > pedestrians.size()) break;
    PedestrianAgent leader = pedestrians.get(g * 3);
    for (int m = 1; m < groupSize; m++) {
        PedestrianAgent follower = pedestrians.get(g * 3 + m);
        follower.setXY(leader.getX() + uniform(-1, 1), leader.getY() + uniform(-1, 1));
        follower.goalX = leader.goalX;
        follower.goalY = leader.goalY;
        follower.speed = leader.speed;
        follower.heading = leader.heading;
    }
}

// Configure robot(s) — right-hand lane (bottom half), going right
// Start at x=50 so pedestrians spawning at x=10 don't overlap with it
for (DeliveryRobot robot : robots) {
    robot.behaviorMode = behaviorMode;
    robot.setXY(50, streetCenter + streetWidth / 4);
    robot.targetY = streetCenter + streetWidth / 4;
    robot.heading = 0; // facing right
    robot.startTime = time();
}]]></StartupCode>
