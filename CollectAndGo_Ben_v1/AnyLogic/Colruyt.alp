					<Body><![CDATA[if (statechart.isStateActive(1773485639867)) {
    return "NORMAL";
} else if (statechart.isStateActive(1773485642114)) {
    return "STOP";
} else if (statechart.isStateActive(1773485651106)) {
    return "CRAWL";
}
return "?";
]]></Body>
