			<Events>
				<Event>
					<Id>1773483925132</Id>
					<Name><![CDATA[event]]></Name>
					<X>200</X><Y>50</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1773483925130</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1773561600000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[0.05]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[
// ================================================================
// STATECHART-DRIVEN PEDESTRIAN BEHAVIOUR
// States: WALKING ↔ DODGING_TRUCK
// Transitions driven by nearestTruckEdgeDist (plain distanceTo)
// ================================================================

// === SECTION 1: PERCEPTION ===

// 1a. Distance to truck center (simple — no body offset)
double truckDist = 999;
double truckAngle = 0;
DeliveryRobot nearRobot = null;
for (DeliveryRobot robot : main.robots) {
    // Ignore robots that are currently parked (loading/unloading)
    if (time() < robot.loadingPauseUntil) continue;
    
    double d = distanceTo(robot);
    if (d < truckDist) {
        truckDist = d;
        truckAngle = Math.atan2(robot.getY() - getY(), robot.getX() - getX());
        nearRobot = robot;
    }
}
this.nearestTruckEdgeDist = truckDist; // drives statechart transitions

// 1b. Nearest pedestrian
double nearPedDist = scanRadius;
double nearPedAngle = 0;
for (PedestrianAgent other : main.pedestrians) {
    if (other == this) continue;
    double d = distanceTo(other);
    if (d < nearPedDist) {
        nearPedDist = d;
        nearPedAngle = Math.atan2(other.getY() - getY(), other.getX() - getX());
    }
}

// 1c. Walls
double distToTop = getY() - main.streetY;
double distToBottom = (main.streetY + main.streetWidth) - getY();


// === SECTION 2: DECISION (state-driven) ===
double goalDir = Math.atan2(goalY - getY(), goalX - getX());
double desiredHeading = goalDir;
double currentSpeed = speed;

if (statechart.isStateActive(DODGING_TRUCK)) {
    // ---- STATE: DODGING_TRUCK ----
    // CURVE AROUND the truck: blend "away from truck" with "toward goal".
    // This makes the pedestrian arc around the truck and continue on,
    // rather than walking purely sideways and getting stuck.
    if (nearRobot != null) {
        // "Away from truck" direction
        double awayDir = Math.atan2(getY() - nearRobot.getY(),
                                     getX() - nearRobot.getX());
        // Blend: closer to truck = more escape, further = more goal
        double proximity = Math.max(0, Math.min(1, 1.0 - (truckDist - 12) / 13.0));
        // proximity=1 at dist=12 (truck edge), 0 at dist=25 (dodge threshold)

        // Weighted circular average of away + goal
        double awayWeight = 0.3 + 0.7 * proximity; // 0.3..1.0
        double goalWeight = 1.0 - awayWeight;
        double ax = awayWeight * Math.cos(awayDir) + goalWeight * Math.cos(goalDir);
        double ay = awayWeight * Math.sin(awayDir) + goalWeight * Math.sin(goalDir);
        desiredHeading = Math.atan2(ay, ax);
        currentSpeed = speed * (0.5 + 0.5 * (1.0 - proximity)); // slow when close
    }
} else {
    // ---- STATE: WALKING ----
    // Normal goal-seeking with pedestrian and wall avoidance.
    double obstDist = nearPedDist;
    double obstAngle = nearPedAngle;
    if (distToTop < obstDist) { obstDist = distToTop; obstAngle = -Math.PI / 2; }
    if (distToBottom < obstDist) { obstDist = distToBottom; obstAngle = Math.PI / 2; }

    if (obstDist < comfortDistance * 0.5) {
        double rel = obstAngle - desiredHeading;
        double ds = (Math.sin(rel) >= 0) ? -1 : 1;
        desiredHeading = desiredHeading + ds * Math.PI / 4;
        currentSpeed = speed * 0.6;
    } else if (obstDist < comfortDistance) {
        double rel = obstAngle - desiredHeading;
        double ds = (Math.sin(rel) >= 0) ? -1 : 1;
        desiredHeading = desiredHeading + ds * Math.PI / 8;
    }
}


// === SECTION 3: ACTION — turn and step ===
double angleDiff = desiredHeading - heading;
while (angleDiff > Math.PI)  angleDiff -= 2 * Math.PI;
while (angleDiff < -Math.PI) angleDiff += 2 * Math.PI;
if (Math.abs(angleDiff) > turnRate) {
    heading += turnRate * Math.signum(angleDiff);
} else {
    heading = desiredHeading;
}

double dt = 0.05;
double newX = getX() + currentSpeed * dt * Math.cos(heading);
double newY = getY() + currentSpeed * dt * Math.sin(heading);

newY = Math.max(main.streetY + 2, Math.min(main.streetY + main.streetWidth - 2, newY));
newX = Math.max(0, Math.min(main.streetLength, newX));

// MOVEMENT CLAMP: if near the truck and this step would bring us
// closer, cancel the step (keep turning in place until facing away).
// This prevents clipping the truck while the heading is still turning.
for (DeliveryRobot robot : main.robots) {
    double curDist = distanceTo(robot);
    double nDx = newX - robot.getX();
    double nDy = newY - robot.getY();
    double newDist = Math.sqrt(nDx * nDx + nDy * nDy);
    if (curDist < 18 && newDist < curDist) {
        // Would move closer — stay in place this tick
        newX = getX();
        newY = getY();
    }
}

setXY(newX, newY);


// === SECTION 5: RESPAWN from a random edge ===
if (distanceTo(goalX, goalY) < 5) {
    double center = main.streetY + main.streetWidth / 2;
    double sx, sy, gx, gy;
    int edge;
    if (uniform(0, 1) < 0.7) {
        edge = (uniform(0, 1) < 0.5) ? 0 : 1;
    } else {
        edge = (uniform(0, 1) < 0.5) ? 2 : 3;
    }
    if (edge == 0) {
        sx = 5;
        sy = center + uniform(5, main.streetWidth / 2 - 5);
        gx = main.streetLength - 5;
        gy = center + uniform(5, main.streetWidth / 2 - 5);
    } else if (edge == 1) {
        sx = main.streetLength - 5;
        sy = main.streetY + uniform(5, main.streetWidth / 2 - 5);
        gx = 5;
        gy = main.streetY + uniform(5, main.streetWidth / 2 - 5);
    } else if (edge == 2) {
        sx = uniform(20, main.streetLength - 20);
        sy = main.streetY + 3;
        gx = uniform(20, main.streetLength - 20);
        gy = main.streetY + main.streetWidth - 3;
    } else {
        sx = uniform(20, main.streetLength - 20);
        sy = main.streetY + main.streetWidth - 3;
        gx = uniform(20, main.streetLength - 20);
        gy = main.streetY + 3;
    }
    setXY(sx, sy);
    goalX = gx;
    goalY = gy;
    intendedY = sy;
    heading = Math.atan2(gy - sy, gx - sx);
}

// === SECTION 6: VISUALS ===
String[] mats = {"Material__1__Surf", "Material__2__Surf", "Material__3__Surf", "Material__4__Surf", "Material__5__Surf", "Material__6__Surf"};
for (String m : mats) {
    if (statechart.isStateActive(STOPPED_FOR_TRUCK)) {
        person.setColor(m, red);
    } else if (statechart.isStateActive(DODGING_TRUCK)) {
        person.setColor(m, orange);
    } else {
        person.setColor(m, green);
    }
}
]]></Action>
				</Event>
			</Events>
