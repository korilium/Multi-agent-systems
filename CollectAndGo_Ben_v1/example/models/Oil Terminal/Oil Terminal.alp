			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1744859304872</Id>
					<Name><![CDATA[connectToTankerTank]]></Name>
					<X>50</X><Y>480</Y>
					<Label><X>15</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[tank]]></Name>
						<Type><![CDATA[TankerTank]]></Type>
					</Parameter>
					<Body><![CDATA[for( FluidExit exit : exits ) {
	if( ! exit.isConnected() ) {
		exit.connect( tank.enter );
		return;
	}
} 
error( "No spare exits to connect to the tanker tank" );]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1744859528897</Id>
					<Name><![CDATA[disconnectFromTanker]]></Name>
					<X>50</X><Y>510</Y>
					<Label><X>15</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[for( FluidExit exit : exits ) {
	exit.disconnect();
}]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1745775723391</Id>
					<Name><![CDATA[low]]></Name>
					<X>400</X><Y>290</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return vOut1.isClosed() && vOut2.isClosed() && vOut3.isClosed() && vOut4.isClosed();]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1745782336711</Id>
					<Name><![CDATA[amount]]></Name>
					<X>400</X><Y>230</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return 
	tank1.amount(CUBIC_METER) + 
	tank2.amount(CUBIC_METER) + 
	tank3.amount(CUBIC_METER) + 
	tank4.amount(CUBIC_METER); 
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1746054894584</Id>
					<Name><![CDATA[utilization]]></Name>
					<X>400</X><Y>260</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return (
	tank1.utilizationTotal() + 
	tank2.utilizationTotal() + 
	tank3.utilizationTotal() + 
	tank4.utilizationTotal() ) / 4;
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1746146465135</Id>
					<Name><![CDATA[reorder]]></Name>
					<X>400</X><Y>320</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[//how much on the way?
double ontheway = totalReordered - pIn1.amountPassedIn(CUBIC_METER);
//how much we need to top up?
double amount = 4 * tankCapacity - ( amount() + ontheway );
if( amount > 0 ) {
	//reorder, note that the actual amount may be different
	double reordered = main.reorder( type, amount );
	totalReordered += reordered;
}]]></Body>
				</Function>
			</Functions>
