			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1744858551091</Id>
					<Name><![CDATA[startLoading]]></Name>
					<X>500</X><Y>3600</Y>
					<Label><X>15</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[tanker]]></Name>
						<Type><![CDATA[Tanker]]></Type>
					</Parameter>
					<Body><![CDATA[for( TankerTank tank : tanker.tanks ) {
	//connect to storage pipes
	ProductStorage storage = null;
	switch( tank.type ) {
		case CrudeOil: storage = storageCrudeOil; break;
		case FuelOil:  storage = storageFuelOil;  break;
		case Diesel:   storage = storageDiesel;   break;
		case Petrol:   storage = storagePetrol;   break;
	}
	storage.connectToTankerTank( tank );	
}]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1744858987282</Id>
					<Name><![CDATA[onLoadingComplete]]></Name>
					<X>500</X><Y>3620</Y>
					<Label><X>15</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[//diconnect from storage pipes
storageCrudeOil.disconnectFromTanker();
storageFuelOil. disconnectFromTanker();
storageDiesel.  disconnectFromTanker();
storagePetrol.  disconnectFromTanker();
//release the tanker from the loading delay block
loading.stopDelayForAll(); ]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1744945781957</Id>
					<Name><![CDATA[setView]]></Name>
					<X>950</X><Y>3320</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[view]]></Name>
						<Type><![CDATA[ViewArea]]></Type>
					</Parameter>
					<Body><![CDATA[if( view == viewActive )
	return;
view.navigateTo();
viewActive = view;
groupMenu.setPos( view.getX(), view.getY() );
double originalWidth = view3D.getWidth();
double viewWidth = view.getWidth();
double scale = viewWidth / originalWidth;
groupMenu.setScale( scale );]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Color]]></ReturnType>
					<Id>1744950078524</Id>
					<Name><![CDATA[productColor]]></Name>
					<X>950</X><Y>3450</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[type]]></Name>
						<Type><![CDATA[ProductType]]></Type>
					</Parameter>
					<Body><![CDATA[switch( type ) {
	case CrudeOil: return colorCrudeOil;
	case FuelOil:  return colorFuelOil;
	case Diesel:   return colorDiesel;
	case Petrol:   return colorPetrol;
}
return null;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1746146538328</Id>
					<Name><![CDATA[reorder]]></Name>
					<X>50</X><Y>3220</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[type]]></Name>
						<Type><![CDATA[ProductType]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[amount]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[//calc number of trains, given their fixed capacity,
//round to the next lower integer
int n = (int)( amount / trainCapacity );
//set type
typeReordered = type;
//create new trains
for( int i=0; i<n; i++ ) {
	newTrain.inject();
}
//return how much actually reordered
return n * trainCapacity;]]></Body>
				</Function>
			</Functions>
