		<!--   =========   Active Object Class   ========  -->
		<ActiveObjectClass>
			<Id>1745776644643</Id>
			<Name><![CDATA[StateStatistics]]></Name>
			<StartupCode><![CDATA[//test parameters validity
if( states == null ) {
    error( "State array not specified" );
} else if( states.length == 0 ) {
    error( "No states are specified" );
} else if( initialState == null ) {
    error( "Initial state not specified" );
}

int index = indexOf( initialState, true );

//create stats structures
stateOccurrences = new int[ states.length ];
timeInStates = new double[ states.length ];
timeInStates = new double[ states.length ];

//set up initial state
currentState = initialState;
stateOccurrences[ index ]++;
updateTime = time();
]]></StartupCode>
			<Generic>false</Generic>
