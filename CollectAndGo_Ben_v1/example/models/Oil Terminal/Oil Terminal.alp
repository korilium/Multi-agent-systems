							<Value Class="CodeValue">
								<Code><![CDATA[//make tugboats move with tanker
for( Agent a : agent.resourceUnits()  ) {
	TugBoat tb = (TugBoat)a; 
	a.setSpeed( 0.5, KN ); //tugging at a lower speed
	a.moveTo( tb.pointAtTankerAtBerth );
}]]></Code>
