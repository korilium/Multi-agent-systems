				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Dump]]></ReturnType>
					<Id>1711704942402</Id>
					<Name><![CDATA[selectDumpToWaste]]></Name>
					<X>3900</X><Y>3220</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (!wasteDumpLeft.isFull()) {
	return wasteDumpLeft;
} else if (!wasteDumpRight.isFull()) {
	return wasteDumpRight; 
} else {
	return unwashedCoalDumpCenter;
}]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Dump]]></ReturnType>
					<Id>1712141722861</Id>
					<Name><![CDATA[selectEPDumpToExtract]]></Name>
					<X>3900</X><Y>3250</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[truck]]></Name>
						<Type><![CDATA[Truck]]></Type>
					</Parameter>
					<Body><![CDATA[truck.dumpEPBinded = EPDumpPoints.keySet().stream()
	.max(Comparator.comparingDouble(Dump::getFreeVolume).reversed())
	.get();
return truck.dumpEPBinded;]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1712149434372</Id>
					<Name><![CDATA[provideMinerTube]]></Name>
					<X>3900</X><Y>3280</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[miner]]></Name>
						<Type><![CDATA[Miner]]></Type>
					</Parameter>
					<Body><![CDATA[var tube = new ShapeLine();
tube.setX(pipe3.getEndPoint().getX());
tube.setY(pipe3.getEndPoint().getY() + triangular(-20, 0, 20));
tube.setZ(pipe3.getEndPoint().getZ());
tube.setEndX(miner.getX());
tube.setEndY(miner.getY());
tube.setEndZ(miner.getZ());
tube.setColor(darkGray);
tube.setVisible(true);
miner.tube = tube;
presentation.add(tube);]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
