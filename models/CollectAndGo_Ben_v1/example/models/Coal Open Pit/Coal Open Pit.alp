			<Functions>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[java.util.Queue<Cell>]]></ReturnType>
					<Id>1710506385503</Id>
					<Name><![CDATA[next]]></Name>
					<X>350</X><Y>100</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[java.util.Queue<Cell> result = new LinkedList<>();
// Note: iterator used for avoid collection ConcurrencyException when delete n for cycle
var iterator = pointsList.listIterator();
while (iterator.hasNext()) {
	var point = iterator.next();
	int x = (int) point.getX();
	int y = (int) point.getY();	
	int min = Math.min(x, y);
	int lastX = columns - 1;
	int lastY = rows - 1;
	// Select only on diagonal, skip others
	if (min > step || x + y > maxRestriction)
		continue;

	// Select all less-equal given diagonal step are presented
	if (!edged && (x <= step || y <= step)) {
		if (revert)
			point = new Point(pointsList.getLast().getX() - point.getX() + 1,
							  pointsList.getLast().getY() - point.getY() + 1,
							  point.getZ());
		result.offer(main.spawnCell(point));
		iterator.remove();
	} else if (edged && 
		(y * lastX - x * lastY <= 0 &&
		 maxRestriction <= lastX + lastY) ||
		(y * lastX - x * lastY >= 0 &&
		 maxRestriction + x + y == 2 * (lastX + lastY))) {
		
		result.offer(main.spawnCell(point));
		iterator.remove();
	}
}
if (maxRestriction % 2 == 1) 
	step++;
maxRestriction++;
return result;]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1710506581763</Id>
					<Name><![CDATA[hasNext]]></Name>
					<X>350</X><Y>160</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return pointsList.size() > 0;]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[java.util.Queue<Cell>]]></ReturnType>
					<Id>1754643489212</Id>
					<Name><![CDATA[nextConcurrent]]></Name>
					<X>350</X><Y>130</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[cellsInProgress]]></Name>
						<Type><![CDATA[HashSet<Point>]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[completedCell]]></Name>
						<Type><![CDATA[Point]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[sliceIndex]]></Name>
						<Type><![CDATA[int]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[mining]]></Name>
						<Type><![CDATA[boolean]]></Type>
					</Parameter>
					<Body><![CDATA[java.util.Queue<Cell> result = new LinkedList<>();
int completedX = (int) completedCell.x;
int completedY = (int) completedCell.y;

var iterator = pointsList.listIterator();
while (iterator.hasNext()) {
	var point = iterator.next();
	
	// Add down cell if exists and if not in progress yet (not mining)
	if (!mining && point.getX() == completedX && point.getY() == completedY + 1) {
		result.offer(main.spawnCell(point));
		iterator.remove();
	}
	
	// Add down cell if exists and on the left edge (start point of the mining line)
	if (mining && point.getX() == 1 && point.getY() == completedY + 1) {
		var cell = main.spawnCell(point);
		cell.priority = rows - (int) point.getY();
		result.offer(cell);
		iterator.remove();
	}
	
	// Add right cell if exists and if not in progress yet
	if (point.getX() == completedX + 1 && point.getY() == completedY) {
		result.offer(main.spawnCell(point));
		iterator.remove();
	}
	
	if (result.size() == 2)
		break;
}

return result;]]></Body>
				</Function>
