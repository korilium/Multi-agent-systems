				<Event>
					<Id>1710336383108</Id>
					<Name><![CDATA[extractionEvent]]></Name>
					<X>3900</X><Y>3100</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>1735307104566</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1710403200000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[0.5]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if (EPLeftExtractionLine.enrichmentPlant.ready)
	EPLeftExtractionLine.source.inject(
		unwashedCoalDumpLeft.extract(ResourcesList.UnwashedCoal,
								 	100).size());
								 
double centerVolumeBalanced = Math.min(unwashedCoalDumpCenter.getVolume() / 2, 100);

if (EPRightExtractionLine.enrichmentPlant.ready)
	EPRightExtractionLine.source.inject(
		unwashedCoalDumpCenter.extract(ResourcesList.UnwashedCoal,
								   	  centerVolumeBalanced).size());
		
if (EPCenterExtractionLine.enrichmentPlant.ready)						   	  
	EPCenterExtractionLine.source.inject(
		unwashedCoalDumpCenter.extract(ResourcesList.UnwashedCoal,
								   	  centerVolumeBalanced).size());
								   	  
if (toExportTank3.isFull()) {
	if (trainDown.exportTrains < 1) {
		trainDown.trainSource.inject();
	}
	if (trainRight.exportTrains < 1) {
		trainRight.trainSource.inject();
	}
}

if (toExportTank1.isFull()) {
	exportTruckSource.inject(10);
}]]></Action>
				</Event>
			</Events>
