			<Functions>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1710838141448</Id>
					<Name><![CDATA[isEdge]]></Name>
					<X>200</X><Y>80</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[point]]></Name>
						<Type><![CDATA[Point]]></Type>
					</Parameter>
					<Body><![CDATA[return point.getX() == 0 || 
	   point.getY() == 0 ||
	   point.getX() == columns - 1 ||
	   point.getY() == rows - 1;]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Task]]></ReturnType>
					<Id>1710852448925</Id>
					<Name><![CDATA[createCleaningTask]]></Name>
					<X>300</X><Y>50</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[var pointSet = new LinkedHashMap<Point, Object>();
for (int i = 0; i < rows; i++) {
	for (int j = 0; j < columns; j++) {
		pointSet.put(points[i][j], null);
		if (j < rows && i < columns)
			pointSet.put(points[j][i], null);
	}
}
var taskPoints = new LinkedList<Point>();
pointSet.forEach((key, value) -> taskPoints.add(key));
return new Task(
	taskPoints,
	TasksList.Cleaning,
	main,
	rows,
	columns);]]></Body>
				</Function>
