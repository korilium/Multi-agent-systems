		<ActiveObjectClass>
			<Id>1708512251587</Id>
			<Name><![CDATA[Main]]></Name>
			<StartupCode><![CDATA[// Fill in collections
// ======================================================
EPDumpPoints.put(slurryDumpEPLeft, EPStop1);
EPDumpPoints.put(slurryDumpEPCenter, EPStop2);
EPDumpPoints.put(slurryDumpEPRight, EPStop3);

wasteDumpPoints.put(wasteDumpLeftStop, wasteDumpLeft);
wasteDumpPoints.put(wasteDumpRightStop, wasteDumpRight);
// ======================================================


// Start Waste Machines
// ======================================================
wasteWMEnter.take(wasteMachine);
unwashedWM1.take(wasteUnwashedMachine1);
unwashedWM2.take(wasteUnwashedMachine2);
coalWM1.take(wasteCoalMachine1);
coalWM2.take(wasteCoalMachine2);
// ======================================================


// Initialize Pit Processing
// ======================================================
spawnPit();
// ======================================================


group2DCameraMenu.setVisible(false);
navigate(view3D);]]></StartupCode>
