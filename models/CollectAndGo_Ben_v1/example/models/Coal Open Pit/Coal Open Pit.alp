			<Functions>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Map<ResourcesList, Double>]]></ReturnType>
					<Id>1709733058515</Id>
					<Name><![CDATA[flotation]]></Name>
					<X>600</X><Y>50</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[pack]]></Name>
						<Type><![CDATA[Pack]]></Type>
					</Parameter>
					<Body><![CDATA[var result = new HashMap<ResourcesList, Double>();
pack.isWet = true;
if (pack.type != ResourcesList.CrushedUnwashedCoal) {
	result.put(pack.type, 1d);
	return result;
}
result.put(ResourcesList.Coal, getCoalRate());
result.put(ResourcesList.InterwashedCoal, getInterwashedRate());
result.put(ResourcesList.Slurry, getSlurryRate());
return result;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1710259248291</Id>
					<Name><![CDATA[getSlurryRate]]></Name>
					<X>600</X><Y>140</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return 1 - BASIC_EFFECTIVENESS - effectiveness * MAX_DELTA_EFFECTIVENESS;]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1710259268137</Id>
					<Name><![CDATA[getCoalRate]]></Name>
					<X>600</X><Y>80</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return 0.9 * (BASIC_EFFECTIVENESS + effectiveness * MAX_DELTA_EFFECTIVENESS);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1710259275087</Id>
					<Name><![CDATA[getInterwashedRate]]></Name>
					<X>600</X><Y>110</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return 0.1 * (BASIC_EFFECTIVENESS + effectiveness * MAX_DELTA_EFFECTIVENESS);]]></Body>
				</Function>
			</Functions>
