					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[switch (type) {
	case Stone:
		return darkGray;
	case UnwashedCoal:
		return silver;
	case Coal:
		return black;
	case Slurry:
		return brown;
	case CrushedUnwashedCoal:
		return gray;
	case InterwashedCoal:
		return yellowGreen;
	default:
		return white;
}]]></Body>
