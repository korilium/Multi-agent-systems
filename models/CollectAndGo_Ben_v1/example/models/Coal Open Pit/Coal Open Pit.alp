			<Functions>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1709722239437</Id>
					<Name><![CDATA[wasteMax]]></Name>
					<X>250</X><Y>80</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[dump]]></Name>
						<Type><![CDATA[Dump]]></Type>
					</Parameter>
					<Body><![CDATA[lastDump = dump;
if (dump.isFull()) return;

pool.forEach((key, value) -> {
	double minVolume = Math.min(value, dump.getFreeVolume());
	dump.fill(key, minVolume);
	pool.put(key, value - minVolume);
});]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1709722266615</Id>
					<Name><![CDATA[load]]></Name>
					<X>250</X><Y>110</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[pool]]></Name>
						<Type><![CDATA[HashMap<ResourcesList, Double>]]></Type>
					</Parameter>
					<Body><![CDATA[pool.forEach(
	(key, value) -> this.pool.merge(
		key,
		value,
		(v1, v2) -> v1 + v2
	)
);]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
