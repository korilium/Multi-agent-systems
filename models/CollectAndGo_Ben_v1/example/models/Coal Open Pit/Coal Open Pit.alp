				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Point]]></ReturnType>
					<Id>1712653396095</Id>
					<Name><![CDATA[getRectCoordinates]]></Name>
					<X>4450</X><Y>2720</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[point]]></Name>
						<Type><![CDATA[Point]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[slice]]></Name>
						<Type><![CDATA[Slice]]></Type>
					</Parameter>
					<Body><![CDATA[return new Point(
	pitRectangle.getX() + (point.getX() + slice.offset.getX()) * 20 * PIT_SCALE,
	pitRectangle.getY() + (point.getY() + slice.offset.getY()) * 20 * PIT_SCALE,
	pitRectangle.getZ() - 20 - (point.getZ() + slice.offset.getZ()) * 20
);]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1712763810150</Id>
					<Name><![CDATA[getMiningProgress]]></Name>
					<X>4450</X><Y>3430</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (currentTier != null) {
	return Math.max(
		(double) (2 * (tierIndex - 1) + currentTier.sliceIndex) / (2 * tiers.size()), 
		0.0);
} else {
	return 0.0;
}]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[Cell]]></ReturnType>
					<Id>1721144746143</Id>
					<Name><![CDATA[spawnSlice]]></Name>
					<X>4450</X><Y>2690</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[slice]]></Name>
						<Type><![CDATA[Slice]]></Type>
					</Parameter>
					<Body><![CDATA[int k = sliceIndex;
slice.points = new Point[slice.rows][slice.columns];
for (int i = 0; i < slice.rows; i++) {
	for (int j = 0; j < slice.columns; j++) {
		var point = new Point(j, i, k);
		var rectABSCoordinates = getRectCoordinates(point, slice);
		var rectangle = new ShapeRectangle();
		rectangle.setZHeight(20);
		rectangle.setWidth(20 * PIT_SCALE);
		rectangle.setHeight(20 * PIT_SCALE);
		rectangle.setFillColor(gray);
		rectangle.setLineWidth(0.5);
		rectangle.setX(rectABSCoordinates.getX());
		rectangle.setY(rectABSCoordinates.getY());
		rectangle.setZ(rectABSCoordinates.getZ());
		presentation.add(rectangle);
		slice.points[i][j] = point;
		slice.rectPoints.put(point, rectangle);
	}
}
pitCell.setZHeight(pitCell.getZHeight() - 20);]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1754642790940</Id>
					<Name><![CDATA[refresh]]></Name>
					<X>3900</X><Y>2790</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[cellsInProgress]]></Name>
						<Type><![CDATA[HashSet<Point>]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[task]]></Name>
						<Type><![CDATA[Task]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[completedCell]]></Name>
						<Type><![CDATA[Point]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[operation]]></Name>
						<Type><![CDATA[Enter]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[mining]]></Name>
						<Type><![CDATA[boolean]]></Type>
					</Parameter>
					<Body><![CDATA[java.util.Queue<Cell> taskQueue = task.nextConcurrent(cellsInProgress, completedCell, sliceIndex, mining);
while (taskQueue.size() > 0) {
	cellsInProgress.add(taskQueue.peek().position);
	operation.take(taskQueue.poll());
}]]></Body>
				</Function>
			</Functions>
