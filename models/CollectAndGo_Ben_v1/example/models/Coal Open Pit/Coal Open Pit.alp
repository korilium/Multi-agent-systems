			<Functions>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Task]]></ReturnType>
					<Id>1709731256303</Id>
					<Name><![CDATA[createPreparingTask]]></Name>
					<X>230</X><Y>80</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[slice]]></Name>
						<Type><![CDATA[Slice]]></Type>
					</Parameter>
					<Body><![CDATA[var task = createTask(slice, TasksList.Preparing);
// remove all non-edged-cells
var iterator = task.pointsList.listIterator();
while (iterator.hasNext()) {
	if (!slice.isEdge(iterator.next()))
		iterator.remove();
}
task.edged = true;
return task;]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Task]]></ReturnType>
					<Id>1709731270842</Id>
					<Name><![CDATA[createMiningTask]]></Name>
					<X>230</X><Y>110</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[slice]]></Name>
						<Type><![CDATA[Slice]]></Type>
					</Parameter>
					<Body><![CDATA[var task = createTask(slice, TasksList.Mining);
// remove all edged-cells
var iterator = task.pointsList.listIterator();
while (iterator.hasNext()) {
	if (slice.isEdge(iterator.next()))
		iterator.remove();
}
return task;]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Task]]></ReturnType>
					<Id>1710510092470</Id>
					<Name><![CDATA[createBackfillTask]]></Name>
					<X>230</X><Y>140</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[slice]]></Name>
						<Type><![CDATA[Slice]]></Type>
					</Parameter>
					<Body><![CDATA[var task = createTask(slice, TasksList.Backfilling);
// remove all edged-cells
var iterator = task.pointsList.listIterator();
while (iterator.hasNext()) {
	if (slice.isEdge(iterator.next()))
		iterator.remove();
}
task.revert = true;
return task;]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[LinkedList<Slice>]]></ReturnType>
					<Id>1710516341263</Id>
					<Name><![CDATA[getSlices]]></Name>
					<X>100</X><Y>110</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return slices;]]></Body>
				</Function>
				<Function AccessType="private" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Task]]></ReturnType>
					<Id>1710852286193</Id>
					<Name><![CDATA[createTask]]></Name>
					<X>200</X><Y>50</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[slice]]></Name>
						<Type><![CDATA[Slice]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[type]]></Name>
						<Type><![CDATA[TasksList]]></Type>
					</Parameter>
					<Body><![CDATA[var pointSet = new LinkedHashMap<Point, Object>();
for (int i = 0; i < slice.rows; i++) {
	for (int j = 0; j < slice.columns; j++) {
		pointSet.put(slice.points[i][j], null);
		if (j < slice.rows && i < slice.columns)
			pointSet.put(slice.points[j][i], null);
	}
}
var taskPoints = new LinkedList<Point>();
pointSet.forEach((key, value) -> taskPoints.add(key));
return new Task(
	taskPoints,
	type,
	main,
	slice.rows,
	slice.columns);]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1711555342132</Id>
					<Name><![CDATA[hasNext]]></Name>
					<X>450</X><Y>80</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return sliceIndex < slices.size();]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Slice]]></ReturnType>
					<Id>1711555359077</Id>
					<Name><![CDATA[next]]></Name>
					<X>450</X><Y>110</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return slices.get(sliceIndex++);]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1711555802998</Id>
					<Name><![CDATA[hasPrevious]]></Name>
					<X>450</X><Y>140</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return sliceIndex > 0;]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Slice]]></ReturnType>
					<Id>1711555814452</Id>
					<Name><![CDATA[previous]]></Name>
					<X>450</X><Y>170</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return slices.get(--sliceIndex);]]></Body>
				</Function>
