				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1754554194533</Id>
					<Name><![CDATA[getProgress]]></Name>
					<X>850</X><Y>170</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (progressStart == infinity)
	return 0;
	
double progress = (time() - progressStart) / processTime;
return Math.min(1, progress);]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1754555588848</Id>
					<Name><![CDATA[getSharpProgress]]></Name>
					<X>850</X><Y>200</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (sharpStart == infinity)
	return 0;
	
double progress = (time() - sharpStart) / processTime;
return Math.min(1, progress);]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1754555805800</Id>
					<Name><![CDATA[startSharping]]></Name>
					<X>400</X><Y>110</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[slice]]></Name>
						<Type><![CDATA[Slice]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[sharpTime]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[double sharpenHeight = rectangle.getZHeight();
double totalSharpen = 2 * (slice.rows + slice.columns - 1);
double sharpenPower = position.getY() <= position.getX() ? 
	position.getY() + position.getX() :
	(totalSharpen / 2 - 1) + ((totalSharpen / 2 - 1) - (position.getY() + position.getX()));
this.sharpLevel = sharpenPower / totalSharpen;
this.sharpStart = time();
this.processTime = sharpTime;]]></Body>
				</Function>
			</Functions>
