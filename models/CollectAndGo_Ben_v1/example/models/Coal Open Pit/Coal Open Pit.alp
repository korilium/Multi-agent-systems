				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1710511807355</Id>
					<Name><![CDATA[execute]]></Name>
					<X>3900</X><Y>2600</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[task]]></Name>
						<Type><![CDATA[Task]]></Type>
					</Parameter>
					<Body><![CDATA[switch (task.type) {
	case Preparing:
		if (!task.hasNext()) {
			send("READY", this);
			return;
		}
		startOperation(drillOperation, task);
		break;
	
	case Mining:
		if (!task.hasNext()) {
			send("DONE", this);
			return;
		}
		startOperation(mineOperation, task);
		break;
	
	case Cleaning:
		if (!task.hasNext()) {
			send("READY", this);
			return;
		}
		startOperation(cleanOperation, task);
		break;
	
	case Backfilling:
		if (!task.hasNext()) {
			send("DONE", this);
			return;
		}
		startOperation(backfillOperation, task);
		break;
}]]></Body>
				</Function>
				<Function AccessType="private" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1710835549488</Id>
					<Name><![CDATA[spawnPit]]></Name>
					<X>4450</X><Y>2630</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// Prepare slices
// ========================================================================================
slices.add(new Slice(PIT_ROWS, PIT_COLUMNS, new Point(0, 0, 0), this)); // Surface Slice
for (int i = 0; i < N_SLICES; i++) {
	slices.add(new Slice(PIT_ROWS - 2 * i, PIT_COLUMNS - 2 * i, new Point(i, i, 0), this));
}
// ========================================================================================


// Prepare tiers
// ========================================================================================
for (int i = 2; i < N_SLICES; i += TIERS_STEP) {
	var tierSlices = new LinkedList<Slice>();
	tierSlices.add(slices.get(i - 1));
	tierSlices.add(slices.get(i));
	tiers.add(new Tier(tierSlices, this));
}
// ========================================================================================]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Cell]]></ReturnType>
					<Id>1710836606587</Id>
					<Name><![CDATA[spawnCell]]></Name>
					<X>4450</X><Y>2660</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[position]]></Name>
						<Type><![CDATA[Point]]></Type>
					</Parameter>
					<Body><![CDATA[var pool = new LinkedHashMap<ResourcesList, Double>();
pool.put(ResourcesList.UnwashedCoal, richnessRate * BASIC_CELL_VOLUME);
pool.put(ResourcesList.Stone, (1 - richnessRate) * BASIC_CELL_VOLUME);
var cell = add_cells(pool, position, PIT_SCALE);
cell.jumpTo(getCellCoordinates(cell, slices.get((int) position.getZ())));
currentSlice.rectPoints.get(position).setVisible(false);
return cell;]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Point]]></ReturnType>
					<Id>1710934482175</Id>
					<Name><![CDATA[getCellCoordinates]]></Name>
					<X>4450</X><Y>2600</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[cell]]></Name>
						<Type><![CDATA[Cell]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[slice]]></Name>
						<Type><![CDATA[Slice]]></Type>
					</Parameter>
					<Body><![CDATA[return new Point(
	pitRectangle.getX() + 10 * PIT_SCALE + (cell.position.getX() + slice.offset.getX()) * 20 * PIT_SCALE,
	pitRectangle.getY() + 10 * PIT_SCALE + (cell.position.getY() + slice.offset.getY()) * 20 * PIT_SCALE,
	pitRectangle.getZ() - 20 - (cell.position.getZ() + slice.offset.getZ()) * 20
);]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1711103005042</Id>
					<Name><![CDATA[loadTrain]]></Name>
					<X>3900</X><Y>3190</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[train]]></Name>
						<Type><![CDATA[Train]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[pool]]></Name>
						<Type><![CDATA[Map<ResourcesList, Double>]]></Type>
					</Parameter>
					<Body><![CDATA[int size = train.size();
for (int i = 1; i < size; i++) {
	((TrainCar) train.getCar(i)).load(
		new HashMap<ResourcesList, Double>(
			pool.entrySet().stream().collect(
				java.util.stream.Collectors.toMap(Map.Entry::getKey, 
					e -> e.getValue() / size)
			)
		)
	);
}]]></Body>
				</Function>
				<Function AccessType="private" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1711106747515</Id>
					<Name><![CDATA[startOperation]]></Name>
					<X>3900</X><Y>2630</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[operation]]></Name>
						<Type><![CDATA[Enter]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[task]]></Name>
						<Type><![CDATA[Task]]></Type>
					</Parameter>
					<Body><![CDATA[java.util.Queue<Cell> taskQueue = new LinkedList<>();
while (taskQueue.size() == 0) {
	taskQueue = task.next();
}
while (taskQueue.size() > 0) {
	cellsInProgress.add(taskQueue.peek().position);
	operation.take(taskQueue.poll());
}]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
