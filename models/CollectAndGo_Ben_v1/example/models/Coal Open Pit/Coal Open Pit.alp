				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[LinkedHashMap<ResourcesList, Double>]]></ReturnType>
					<Id>1710930722549</Id>
					<Name><![CDATA[getPool]]></Name>
					<X>550</X><Y>50</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return isDrilled && isCharged ? new LinkedHashMap<ResourcesList, Double>(pool.entrySet().stream().collect(java.util.stream.Collectors.toMap(Map.Entry::getKey, e -> e.getValue() / 2)))
	: pool;]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1711535728611</Id>
					<Name><![CDATA[sharp]]></Name>
					<X>400</X><Y>140</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[slice]]></Name>
						<Type><![CDATA[Slice]]></Type>
					</Parameter>
					<Body><![CDATA[durability = 0.1 * maxDurability;
rectangle.setFillColor(gravelTexture);
rectangle.setLineColor(transparent);
rectangle.setZHeight(100 * (1 - sharpLevel));]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1711619173356</Id>
					<Name><![CDATA[backfill]]></Name>
					<X>400</X><Y>170</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[waste]]></Name>
						<Type><![CDATA[Map<ResourcesList, Double>]]></Type>
					</Parameter>
					<Body><![CDATA[durability = maxDurability;
rectangle.setFillColor(gravelTexture);
rectangle.setLineColor(transparent);
waste.forEach(
	(key, value) -> this.pool.merge(
		key,
		value,
		(v1, v2) -> v1 + v2
	)
);]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
