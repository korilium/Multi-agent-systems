					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (number == 1) {
	return main.coalEP1;
} else if (number == 2) {
	return main.coalEP2;
} else if (number == 3) {
	return main.coalEP3;
} else {
	return null;	
}]]></Body>
				</Function>
