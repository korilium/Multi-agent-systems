			<Functions>
				<Function AccessType="private" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1709804598517</Id>
					<Name><![CDATA[engageFlotation]]></Name>
					<X>-200</X><Y>600</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (cyclicBarrier.size() == FLOTATION_CAPACITY && 
	flotation.size() == 0 &&
	distribution.size() == 0) {
	
	cyclicBarrier.stopDelayForAll();
	flotationTimes++;
}]]></Body>
				</Function>
				<Function AccessType="private" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1709805990931</Id>
					<Name><![CDATA[engageDistribution]]></Name>
					<X>-200</X><Y>630</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (flotation.size() == 0 &&
	distribution.size() == FLOTATION_CAPACITY) {

	oldFlotationOutput = flotationOutput;
	flotationOutput = new LinkedHashMap<>();
	distribution.stopDelayForAll();
}]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[FluidEnter]]></ReturnType>
