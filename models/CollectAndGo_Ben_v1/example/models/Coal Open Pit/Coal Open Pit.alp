				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1709723574762</Id>
					<Name><![CDATA[getVolume]]></Name>
					<X>650</X><Y>50</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return pool.values().stream().mapToDouble(t -> t).sum();]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1709725884550</Id>
					<Name><![CDATA[fill]]></Name>
					<X>650</X><Y>140</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[resourcesList]]></Name>
						<Type><![CDATA[ResourcesList]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[amount]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[pool.merge(resourcesList, amount, (v1, v2) -> v1 + v2);
grow(amount);]]></Body>
				</Function>
				<Function AccessType="private" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1709726503963</Id>
					<Name><![CDATA[grow]]></Name>
					<X>400</X><Y>110</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[amount]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[height += (amount / maxVolume) * MAX_HEIGHT;]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Map<ResourcesList, Double>]]></ReturnType>
					<Id>1710336561993</Id>
					<Name><![CDATA[extract]]></Name>
					<X>650</X><Y>170</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[resourcesList]]></Name>
						<Type><![CDATA[ResourcesList]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[amount]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[var result = new HashMap<ResourcesList, Double>();
if (pool.containsKey(resourcesList) && pool.get(resourcesList) >= amount) {
	result.put(resourcesList, amount);
	pool.merge(resourcesList, amount, (v1, v2) -> v1 - v2);
	grow(-amount);
}
return result;]]></Body>
				</Function>
